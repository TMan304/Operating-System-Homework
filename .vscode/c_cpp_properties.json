{
  "configurations": [
    {
      "name": "windows-gcc-x64",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "browse": {
        "limitSymbolsToIncludedHeaders": true,
        "databaseFilename": ""
      },
      "defines": [
        "__GNUC__",
        "__KERNEL__",
        "MODULE"
      ],
      "intelliSenseMode": "windows-gcc-x64",
      "compilerPath": "E:/Tool/mingw64/bin/gcc.exe",
      "cStandard": "${default}",
      "cppStandard": "${default}"
    }
  ],
  "version": 4
}